    def decode_weights(self):
        idx = 0
        self.weights = []
        self.biases = []

        # 输入层 → 第一隐藏层
        w1_size = INPUT_NODES * HIDDEN_NODES
        W1 = self.dna[idx:idx + w1_size].reshape(INPUT_NODES, HIDDEN_NODES)
        idx += w1_size
        b1_size = HIDDEN_NODES
        b1 = self.dna[idx:idx + b1_size]
        idx += b1_size
        self.weights.append(W1)
        self.biases.append(b1)

        # 中间隐藏层（如果 HIDDEN_NUMBER > 1）
        for _ in range(HIDDEN_NUMBER - 1):
            w_size = HIDDEN_NODES * HIDDEN_NODES
            W = self.dna[idx:idx + w_size].reshape(HIDDEN_NODES, HIDDEN_NODES)
            idx += w_size
            b_size = HIDDEN_NODES
            b = self.dna[idx:idx + b_size]
            idx += b_size
            self.weights.append(W)
            self.biases.append(b)

        # 最后隐藏层 → 输出层
        w_out_size = HIDDEN_NODES * OUTPUT_NODES
        W_out = self.dna[idx:idx + w_out_size].reshape(HIDDEN_NODES, OUTPUT_NODES)
        idx += w_out_size
        b_out_size = OUTPUT_NODES
        b_out = self.dna[idx:idx + b_out_size]
        self.weights.append(W_out)
        self.biases.append(b_out)

    def get_sense_0(self):
        """获取感知输入：转换世界相对坐标为基于自身车头朝向的局部相对坐标"""
        # 获取所有存活的敌对生物
        others = [c for c in self.population.creatures if c is not self and c.alive]

        # 兜底：如果没有其他生物，给神经网络输入默认值（全0，维持当前状态）
        if not others:
            return np.array([
                0.,
                0.0, 0.0,  # 局部相对位置 (前/后, 右/左)
                1.0,  # 距离归一化（1.0表示极远或没有目标）
                max(0.0, self.energy) / MAX_ENERGY,
                self.hp / HP_INIT,
                1.0  # 偏置常数
            ])

        # 找到最近的敌人
        closest = min(others, key=lambda c: distance(self, c))
        dist = distance(self, closest)

        # 兜底：如果敌人超出了视野范围
        if dist > VISION_RANGE:
            return np.array([
                0.0,
                0.0, 0.0,
                1.0,
                max(0.0, self.energy) / MAX_ENERGY,
                self.hp / HP_INIT,
                1.0
            ])

        # ========== 核心：局部坐标系转换 ==========

        # 1. 计算从“我”指向“敌人”的世界坐标系向量 (3D Vec3)
        # Ursina 中：+X 是右，+Y 是上，+Z 是前
        to_target = closest.position - self.position
        # 将高度差 Y 清零，只保留地面 X-Z 平面的向量并归一化
        to_target_2d = Vec3(to_target.x, 0, to_target.z).normalized()

        # 2. 获取生物当前车头的正前方向量 (已由 Ursina 自动随 rotation_y 更新，且为单位向量)
        my_forward = self.forward.normalized()

        # 3. 点积 (Dot Product) -> 判断目标在 [前/后]
        # 当两个单位向量完全同向时为 1.0 (正前方)，完全反向时为 -1.0 (正后方)
        forward_component = my_forward.dot(to_target_2d)

        # 4. 叉积 (Cross Product) -> 判断目标在 [右/左]
        # 3D向量叉积得到一个垂直于地面的向量，其 Y 轴的正负号直接反映了左右关系
        # 在 Ursina 右手坐标系下：Y为正表示目标在右手边，Y为负表示目标在左手边
        cross_product = my_forward.cross(to_target_2d)
        right_component = cross_product.y

        # ========== 组装输入向量 ==========
        # 所有输入范围均控制在 [-1.0, 1.0] 之间，极度利于神经网络收敛
        return np.array([
            closest.hp,
            forward_component,  # 前后感受：1.0(正前), -1.0(正后)
            right_component,  # 左右感受：1.0(正右), -1.0(正左)
            dist / VISION_RANGE,  # 距离感受：0.0(贴脸), 1.0(视野边缘)
            max(0.0, self.energy) / MAX_ENERGY,  # 自身能量比例 [0, 1]
            self.hp / HP_INIT,  # 自身血量比例 [0, 1]
            1.0  # 偏置项
        ])

    def get_senses(self):
        """获取感知输入：转换世界相对坐标为基于自身车头朝向的局部相对坐标"""
        def _relative_info(target):
            """计算目标相对于自身的局部坐标信息
            返回：(forward_component, right_component, distance_normalized)
            """
            to_target = target.position - self.position
            dist = distance(self, target)
            dist_norm = dist / VISION_RANGE

            # 计算水平方向上的单位方向向量（忽略y轴）
            to_target_2d = Vec3(to_target.x, 0, to_target.z)
            if to_target_2d.length() > 0:
                to_target_2d = to_target_2d.normalized()
            else:
                to_target_2d = Vec3(0, 0, 0)

            my_forward = self.forward.normalized()
            forward_component = my_forward.dot(to_target_2d)
            cross_product = my_forward.cross(to_target_2d)
            right_component = cross_product.y  # 叉积的y分量表示左右方向

            return forward_component, right_component, dist_norm

        # ========== 2. 敌人感知（视野内非亲属、非自身，取最近3个） ==========
        MAX_ENEMIES = 3
        enemies = []
        for c in self.population.creatures:
            if c is self :
                continue
            if distance(self, c) < VISION_RANGE:
                enemies.append(c)
        # 按距离排序，取最近的 MAX_ENEMIES 个
        enemies.sort(key=lambda e: distance(self, e))
        enemies = enemies[:MAX_ENEMIES]

        enemy_senses = []
        for enemy in enemies:
            fwd, right, dist_norm = _relative_info(enemy)
            enemy_senses.extend([enemy.hp, fwd, right, dist_norm])
        # 不足 MAX_ENEMIES 个时填充0
        while len(enemy_senses) < MAX_ENEMIES * 3:
            enemy_senses.extend([0.0, 0.0, 0.0, 0.0])

        # ========== 3. 自身属性 ==========
        self_senses = [
            max(0.0, self.energy) / MAX_ENERGY,
            self.hp / HP_INIT,
            1.0  # 偏置项
        ]

        # 合并所有感知
        return np.array(enemy_senses + self_senses)
    def think(self, inputs):
        # 隐藏层传播
        hidden = np.array(inputs)
        for i in range(HIDDEN_NUMBER):
            hidden = np.tanh(np.dot(hidden, self.weights[i]) + self.biases[i])
        # 输出层（最后存储的权重是输出层的）
        outputs = np.dot(hidden, self.weights[-1]) + self.biases[-1]
        turn = np.tanh(outputs[0])
        throttle = 1.0 / (1.0 + np.exp(-outputs[1]))
        attack_intent = 1.0 / (1.0 + np.exp(-outputs[2]))
        return turn, throttle, attack_intent

    def attack_target(self, target):
        """攻击目标生物"""
        if self.attack_cooldown > 0:  # 为冷却则无法攻击
            return
        self.attack_cooldown = ATTACK_COOLDOWN
        target.hp -= ATTACK_DAMAGE  # 对目标生物造成伤害
        self.energy -= 单次攻击所消耗的能量          # 攻击消耗能量
        if target.hp <= 0:  # 目标生物血条清零则亡
            target.die()
            self.kills += 1
            self.hp = min(self.hp + 击杀治愈, HP_INIT)
            self.energy = min(self.energy + KILL_ENERGY, MAX_ENERGY)

    def die(self):
        """死亡处理：记录适应度并标记为死亡"""
        if not self.alive:
            return
        self.alive = False
        self.fitness = self.survival_time + self.kills * 500
        self.population.dead_records.append((self.dna.copy(), self.fitness))  # 与种群管理器交流

        # 死亡时：固定标签在当前位置，变红变大，显示死亡信息
        self.tag.position = self.position + Vec3(0, 0.8, 0)
        self.tag.text = f'enger:{self.energy:.1f} | kills:{self.kills} | s_t: {self.survival_time:.1f} | fitness:{round(self.fitness, 2)}'
        self.tag.color = color.red
    def update(self):
        """每帧更新：代谢、感知、决策、移动、攻击"""
        if not self.alive:
            return
        self.survival_step += 1
        dt = time.dt
        self.survival_time += dt
        self.energy -= METABOLISM * dt
        if self.energy <= 0:  # 能量为0时， 扣生命值，不断减少速度
            self.max_speed = MAX_SPEED * self.hp /HP_INIT
            self.hp -= 0.001
        else:
            self.max_speed = MAX_SPEED
        if self.hp <= 0 :  # 能量或生命值低于0时触发死亡
            self.die()
            return

        if self.attack_cooldown > 0:
            self.attack_cooldown -= dt

        # 感知 -> 决策
        inputs = self.get_senses()
        turn, throttle, attack_intent = self.think(inputs)

        # 执行移动决策
        self.rotation_y += turn * MAX_TURN * dt
        self.speed = throttle * self.max_speed
        self.position += self.forward * self.speed * dt

        # 边界限制
        self.x = max(-BOUNDARY, min(BOUNDARY, self.x))
        self.z = max(-BOUNDARY, min(BOUNDARY, self.z))

        # 执行攻击
        if attack_intent > 0.5:
            others = [c for c in self.population.creatures if c is not self and c.alive]
            if others:
                closest = min(others, key=lambda c: distance(self, c))
                if distance(self, closest) <= ATTACK_RANGE:
                    self.attack_target(closest)

        # 颜色反映能量高低
        ratio = self.energy / MAX_ENERGY
        self.color = color.rgb(1 - ratio, ratio, 0.2)

        # 存活时：更新标签位置和内容
        self.tag.position = self.position + Vec3(0, 0.8, 0)
        self.tag.text = f'hp: {self.hp} | enger:{round(self.energy, 2)} | kills:{self.kills}'


class Population:
    """种群管理器"""
    def __init__(self):
        self.img = None
        self.creatures = []   # 种群容器
        self.death_creatures = []
        self.dead_records = []  # 储存本代所有个体的(基因, 适应度)
        self.generation = 1    # 进化代数
        self.step_count = 0    # 步数
        self.max_fitness = 0
        self.max_fitness_s = []
        self.max_kill = 0
        self.average_fitness = 0
        self.average_fitness_s = []  # 平均适应度
        self.fig = Entity(
            model='quad',
            texture=None,  # 初始为空，稍后动态更新
            position=(0, 15, 50),  # 放置在场景中合适的位置
            scale=(40, 30),  # 宽度4，高度3
            double_sided=True
        )  # 用于展示统计面版的 面实体
        self.create_generation()  # 创建第一代

    def create_generation(self):
        """创建第一代（随机基因）"""

        for c in self.creatures:
            if c.tag:
                destroy(c.tag)
            destroy(c)
        self.creatures.clear()
        self.dead_records.clear()
        self.step_count = 0
        for _ in range(POP_SIZE):
            c = Creature(population=self)
            self.creatures.append(c)

    "============遗传算法============"
    def evolve(self):
        # 收集适应度并销毁当前生物（标签会随生物一起被 destroy）
        # """遗传算法：收集适应度，选择、交叉、变异，生成新一代"""
        fitness = []
        kills = []
        for c in self.creatures:
            if c.alive:
                c.fitness = c.survival_step/self.step_count * 存活时间在适应度中的权重 + c.kills * 击杀数在适应度中的权重 + c.hp/HP_INIT * hp在适应度中的权重
                self.dead_records.append((c.dna.copy(), c.fitness))
                kills.append(c.kills)
                fitness.append(c.fitness)
            destroy(c.tag)
            destroy(c)
        for dc in self.death_creatures:
            destroy(dc.tag)
            kills.append(dc.kills)
            fitness.append(dc.fitness)
            destroy(dc)
        self.creatures.clear()
        self.death_creatures.clear()
        # 收集仍存活个体的数据
        self.average_fitness = sum(fitness) / len(fitness)
        self.average_fitness_s.append(self.average_fitness)
        if not self.dead_records:
            self.create_generation()
            self.generation += 1
            return

        # 按适应度降序排列
        self.dead_records.sort(key=lambda x: x[1], reverse=True)
        self.max_fitness = self.dead_records[0][-1]
        self.max_fitness_s.append(self.max_fitness)
        total_fitness = sum(f for _, f in self.dead_records) or 1
        # 提取击杀数

        self.max_kill = max(kills)
        # 精英保留
        new_dnas = []
        for i in range(ELITE_COUNT):
            if i < len(self.dead_records):
                new_dnas.append(self.dead_records[i][0].copy())

        # 轮盘赌生成剩余个体
        while len(new_dnas) < POP_SIZE:
            parent1 = self.roulette_select(total_fitness)
            parent2 = self.roulette_select(total_fitness)
            # 交叉
            if random.random() < CROSSOVER_RATE:
                cp = random.randint(1, GENE_LENGTH - 1)
                child = np.concatenate([parent1[:cp], parent2[cp:]])
            else:
                child = parent1.copy()
            # 变异
            for i in range(GENE_LENGTH):
                if random.random() < MUTATION_RATE:
                    child[i] += random.gauss(0, MUTATION_SCALE)
            new_dnas.append(child)

        self.dead_records.clear()

        # 实例化新一代生物
        for dna in new_dnas:
            self.creatures.append(Creature(population=self, dna=dna))

        self.generation += 1
        self.step_count = 0

    def roulette_select(self, total_fitness):
        """适应度比例选择"""
        pick = random.random() * total_fitness
        current = 0
        for dna, fit in self.dead_records:
            current += fit
            if current >= pick:
                return dna
        return self.dead_records[-1][0]

    "==========统计图========="
    def draw_line(self):
        """根据当前数据生成【双Y轴】折线统计图的纹理（已修复 TypeError 和除零崩溃）"""
        gens = list(range(1, len(self.max_fitness_s) + 1))
        max_vals = self.max_fitness_s
        avg_vals = self.average_fitness_s

        # 兜底1：无数据时返回空白纹理
        if not gens or not max_vals or not avg_vals:
            return Texture(Image.new('RGBA', (10, 10), (255, 255, 255, 255)))

        # ----- 1. 图片尺寸与留白 -----
        width, height = 900, 600
        margin_left = 90
        margin_right = 90
        margin_top = 80
        margin_bottom = 80

        plot_width = width - margin_left - margin_right
        plot_height = height - margin_top - margin_bottom

        # ----- 2. 计算左右Y轴的各自范围（增强兜底，防止单个 float 报错与除零） -----
        # 处理左轴（最大适应度）
        y1_raw_min = min(max_vals) if isinstance(max_vals, (list, np.ndarray)) else max_vals
        y1_raw_max = max(max_vals) if isinstance(max_vals, (list, np.ndarray)) else max_vals

        if y1_raw_max == y1_raw_min:
            y1_min, y1_max = y1_raw_min - 1.0, y1_raw_max + 1.0
        else:
            y1_padding = (y1_raw_max - y1_raw_min) * 0.1
            y1_min = y1_raw_min - y1_padding
            y1_max = y1_raw_max + y1_padding

        # 处理右轴（平均适应度）
        y2_raw_min = min(avg_vals) if isinstance(avg_vals, (list, np.ndarray)) else avg_vals
        y2_raw_max = max(avg_vals) if isinstance(avg_vals, (list, np.ndarray)) else avg_vals

        if y2_raw_max == y2_raw_min:
            y2_min, y2_max = y2_raw_min - 1.0, y2_raw_max + 1.0
        else:
            y2_padding = (y2_raw_max - y2_raw_min) * 0.1
            y2_min = y2_raw_min - y2_padding
            y2_max = y2_raw_max + y2_padding

        # ----- 3. 坐标映射函数 -----
        def map_x(gen):
            if len(gens) <= 1:
                return margin_left + plot_width / 2
            return margin_left + (gen - 1) / (len(gens) - 1) * plot_width

        def map_y_left(value):
            return height - margin_bottom - (value - y1_min) / (y1_max - y1_min) * plot_height

        def map_y_right(value):
            return height - margin_bottom - (value - y2_min) / (y2_max - y2_min) * plot_height

        # ----- 4. 绘制图像 -----
        img = Image.new('RGBA', (width, height), (255, 255, 255, 255))
        draw = ImageDraw.Draw(img)

        try:
            font = ImageFont.truetype("arial.ttf", 22)
            small_font = ImageFont.truetype("arial.ttf", 16)
        except:
            font = ImageFont.load_default()
            small_font = font

        # ----- 5. 绘制三条轴线 -----
        draw.line([(margin_left, height - margin_bottom), (width - margin_right, height - margin_bottom)], fill='black',
                  width=3)
        draw.line([(margin_left, margin_top), (margin_left, height - margin_bottom)], fill='red', width=3)
        draw.line([(width - margin_right, margin_top), (width - margin_right, height - margin_bottom)], fill='blue',
                  width=3)

        # ----- 6. 绘制刻度和标签 -----
        max_x_ticks = 10
        step = max(1, len(gens) // max_x_ticks)
        for i in range(0, len(gens), step):
            gen = gens[i]
            x = map_x(gen)
            draw.line([(x, height - margin_bottom), (x, height - margin_bottom + 5)], fill='black', width=2)
            draw.text((x - 10, height - margin_bottom + 10), str(gen), fill='black', font=small_font)

        if len(gens) > 1 and (len(gens) - 1) % step != 0:
            x = map_x(gens[-1])
            draw.line([(x, height - margin_bottom), (x, height - margin_bottom + 5)], fill='black', width=2)
            draw.text((x - 10, height - margin_bottom + 10), str(gens[-1]), fill='black', font=small_font)

        # 左Y轴刻度 (Max Fitness)
        for i in range(5):
            t = i / 4
            val = y1_min + t * (y1_max - y1_min)
            y = map_y_left(val)
            draw.line([(margin_left - 5, y), (margin_left, y)], fill='red', width=2)
            draw.text((margin_left - 75, y - 8), f'{val:.1f}', fill='red', font=small_font)

        # 右Y轴刻度 (Avg Fitness)
        for i in range(5):
            t = i / 4
            val = y2_min + t * (y2_max - y2_min)
            y = map_y_right(val)
            draw.line([(width - margin_right, y), (width - margin_right + 5, y)], fill='blue', width=2)
            draw.text((width - margin_right + 12, y - 8), f'{val:.1f}', fill='blue', font=small_font)

        # 轴标题
        draw.text((width // 2 - 50, height - 35), "Generation", fill='black', font=font)
        draw.text((20, margin_top - 40), "Max Fitness (Left)", fill='red', font=font)
        draw.text((width - 220, margin_top - 40), "Avg Fitness (Right)", fill='blue', font=font)

        # ----- 7. 绘制双轴折线 -----
        # 左轴曲线 (红色)
        max_points = [(map_x(g), map_y_left(v)) for g, v in zip(gens, max_vals)]
        if len(max_points) > 1:
            draw.line(max_points, fill='red', width=4)
        for x, y in max_points:
            draw.ellipse([x - 5, y - 5, x + 5, y + 5], fill='red')

        # 右轴曲线 (蓝色)
        avg_points = [(map_x(g), map_y_right(v)) for g, v in zip(gens, avg_vals)]
        if len(avg_points) > 1:
            draw.line(avg_points, fill='blue', width=4)
        for x, y in avg_points:
            draw.ellipse([x - 5, y - 5, x + 5, y + 5], fill='blue')
        self.img = img
        # ----- 8. 返回 Ursina 纹理 -----
        return Texture(img)
    "==========更新函数========"  # 此局开始到 下一代生成过程，均在这里
    def update(self):
        self.step_count += 1
        # 更新所有生物，移除已死亡实体
        idc = 0
        for c in self.creatures[:]:
            if c.alive:
                c.update()
                # self.text[idc].position = (c.position[0], c.position[1]+0.5, c.position[2])
                # self.text[idc].text = f'hp: {c.hp} | enger:{round(c.energy, 2)} | kills:{c.kills}'
                # self.text[idc].color = color.white33
                # self.text[idc].scale = 10
            else:
                self.death_creatures.append(c)
                self.creatures.remove(c)
            # self.text[idc].look_at(camera)
            idc += 1


        # 达到终止条件则进化
        if len(self.creatures) == 0 or self.step_count >= MAX_STEPS:
            self.evolve()
            self.fig.texture = self.draw_line()
            # new_tex = self.draw_line()
            # self.fig.texture = new_tex

    def save_data(self, is_snapshot=False):
        """保存末代优秀DNA（降序）与统计图表
        is_snapshot: 为 True 代表快捷键快照（不影响后续运行），False 代表退出保存
        """
        label = "手动快照" if is_snapshot else "退出退出"
        print(f"\n[系统提示] 触发【{label}】，正在保存当前演化成果...")

        # 1. 收集并计算当前所有个体的即时适应度
        current_records = []
        for c in self.creatures:
            fit = (
                    (c.survival_step / max(1, self.step_count)) * 存活时间在适应度中的权重
                    + c.kills * 击杀数在适应度中的权重
                    + (c.hp / HP_INIT) * hp在适应度中的权重
            )
            current_records.append({
                "fitness": float(fit),
                "kills": int(c.kills),
                "dna": c.dna.tolist()
            })

        for dna, fit in self.dead_records:
            current_records.append({
                "fitness": float(fit),
                "kills": 0,
                "dna": dna.tolist()
            })

        if not current_records:
            print("[警告] 没有找到任何个体数据，取消保存。")
            return

        # 2. 按适应度【降序】排列
        current_records.sort(key=lambda x: x["fitness"], reverse=True)

        # 3. 文件命名区分（快照会带上标记，防止覆盖）
        suffix = "_snapshot" if is_snapshot else ""
        dna_filename = f"generation_{self.generation}{suffix}_dna_list.json"
        img_filename = f"generation_{self.generation}{suffix}_fitness_chart.png"

        # 4. 保存 JSON 基因库
        try:
            with open(dna_filename, "w", encoding="utf-8") as f:
                json.dump(current_records, f, indent=4, ensure_ascii=False)
            print(f" 成功：当前第 {self.generation} 代共 {len(current_records)} 个基因已保存 -> {dna_filename}")
        except Exception as e:
            print(f" 失败：保存基因文件时出错: {e}")

        # 5. 保存统计图表图片
        try:
            if self.img:
                self.img.save(img_filename)
                print(f" 成功：双Y轴统计图表已保存 -> {img_filename}")
            else:
                print(" 提示：当前图表尚未生成（可能还在第一代运行中），未截取到图表。")
        except Exception as e:
            print(f" 失败：保存统计图表时出错: {e}")




