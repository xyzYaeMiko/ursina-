            else:
                self.death_creatures.append(c)
                self.creatures.remove(c)
            # self.text[idc].look_at(camera)
            idc += 1


        # 达到终止条件则进化
        if len(self.creatures) == 0 or self.step_count >= MAX_STEPS:
            self.evolve()
            self.fig.texture = self.draw_line()
