    def save_data(self, is_snapshot=False):
        """保存末代优秀DNA（降序）与统计图表
        is_snapshot: 为 True 代表快捷键快照（不影响后续运行），False 代表退出保存
        """
        label = "手动快照" if is_snapshot else "退出退出"
        print(f"\n[系统提示] 触发【{label}】，正在保存当前演化成果...")

        # 1. 收集并计算当前所有个体的即时适应度
        current_records = []
        for c in self.creatures:
            fit = (
                    (c.survival_step / max(1, self.step_count)) * 存活时间在适应度中的权重
                    + c.kills * 击杀数在适应度中的权重
                    + (c.hp / HP_INIT) * hp在适应度中的权重
            )
            current_records.append({
                "fitness": float(fit),
                "kills": int(c.kills),
                "dna": c.dna.tolist()
            })

        for dna, fit in self.dead_records:
            current_records.append({
                "fitness": float(fit),
                "kills": 0,
                "dna": dna.tolist()
            })

        if not current_records:
            print("[警告] 没有找到任何个体数据，取消保存。")
            return

        # 2. 按适应度【降序】排列
        current_records.sort(key=lambda x: x["fitness"], reverse=True)

        # 3. 文件命名区分（快照会带上标记，防止覆盖）
        suffix = "_snapshot" if is_snapshot else ""
        dna_filename = f"generation_{self.generation}{suffix}_dna_list.json"
        img_filename = f"generation_{self.generation}{suffix}_fitness_chart.png"

        # 4. 保存 JSON 基因库
        try:
            with open(dna_filename, "w", encoding="utf-8") as f:
                json.dump(current_records, f, indent=4, ensure_ascii=False)
            print(f" 成功：当前第 {self.generation} 代共 {len(current_records)} 个基因已保存 -> {dna_filename}")
        except Exception as e:
            print(f" 失败：保存基因文件时出错: {e}")

        # 5. 保存统计图表图片
        try:
            if self.img:
                self.img.save(img_filename)
                print(f" 成功：双Y轴统计图表已保存 -> {img_filename}")
            else:
                print(" 提示：当前图表尚未生成（可能还在第一代运行中），未截取到图表。")
        except Exception as e:
            print(f" 失败：保存统计图表时出错: {e}")




