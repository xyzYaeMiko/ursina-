# ========== 参数设置 ==========
POP_SIZE = 50  # 种群数量
MAX_STEPS = 500  # 每代最大运行帧数
VISION_RANGE = 20  # 视野半径
MAX_SPEED = 10.0  # 最大移动速度
MAX_TURN = 120.0  # 最大转向速度(度/秒)
ATTACK_RANGE = 2.5  # 攻击距离
ATTACK_COOLDOWN = 0.5  # 攻击冷却(秒)
ATTACK_DAMAGE = 3  # 每次攻击伤害
HP_INIT = 10  # 初始生命值
ENERGY_INIT = 100.0  # 初始能量
METABOLISM = 1.0  # 每秒能量消耗
单次攻击所消耗的能量 = 5
KILL_ENERGY = 30.0  # 杀死敌人获得的能量
MAX_ENERGY = 200.0  # 能量上限

存活时间在适应度中的权重 = 50
击杀数在适应度中的权重 = 10
hp在适应度中的权重 = 50

INPUT_NODES = 6  # 神经网络输入层
HIDDEN_NODES = 8  # 隐藏层节点数
HIDDEN_NUMBER = 3  # 隐藏层层数
OUTPUT_NODES = 3  # 输出层(转向、加速、攻击)

MUTATION_RATE = 0.1  # 每个基因变异概率
MUTATION_SCALE = 0.5  # 变异幅度
ELITE_COUNT = 10  # 精英保留数量
CROSSOVER_RATE = 0.7  # 交叉概率
BOUNDARY = 50  # 平面边界

# 根据 HIDDEN_NUMBER 动态计算基因长度
def calc_gene_length():
    length = INPUT_NODES * HIDDEN_NODES          # input -> first hidden
    length += HIDDEN_NODES                       # bias of first hidden
    for _ in range(HIDDEN_NUMBER - 1):           # inter hidden layers
        length += HIDDEN_NODES * HIDDEN_NODES
        length += HIDDEN_NODES
    length += HIDDEN_NODES * OUTPUT_NODES        # last hidden -> output
    length += OUTPUT_NODES
    return length

GENE_LENGTH = calc_gene_length()

# 基因总长度（权重和偏置）
# GENE_LENGTH = (INPUT_NODES * HIDDEN_NODES   # 输入到隐藏
